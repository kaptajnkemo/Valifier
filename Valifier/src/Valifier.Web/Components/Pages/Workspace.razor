@page "/workspace"
@inject GetPlatformOverviewQueryHandler OverviewHandler

<PageTitle>Workspace map</PageTitle>

@if (_overview is null)
{
    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudStack Spacing="3">
        <MudText Typo="Typo.h3">Workspace map</MudText>
        <MudText Typo="Typo.body1">The starter solution maps every major platform module into a single operational surface so later feature work has a clear landing zone.</MudText>

        <MudGrid Spacing="3">
            @foreach (var module in _overview.Modules)
            {
                <MudItem xs="12" md="6">
                    <MudPaper Class="surface-card" Elevation="0">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.h6">@module.Name</MudText>
                            <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary">@module.Stage</MudChip>
                        </MudStack>
                        <MudText Typo="Typo.body2">@module.Purpose</MudText>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    </MudStack>
}

@code {
    private PlatformOverview? _overview;

    protected override async Task OnInitializedAsync()
    {
        _overview = await OverviewHandler.HandleAsync(new GetPlatformOverviewQuery());
    }
}
