@page "/sign-in"
@model Valifier.Web.Pages.SignInModel
@{
    ViewData["Title"] = "Sign in";
}

<section class="vf-panel">
    <div class="vf-eyebrow">Shared access</div>
    <h1>Sign in</h1>
    <p class="vf-copy">Use the Global Admin account, a tenant superuser account, or a provisioned Hiring Manager account.</p>

    <form method="post" class="vf-form">
        <div asp-validation-summary="ModelOnly" class="vf-validation"></div>

        <label class="vf-field">
            <span>Email</span>
            <input asp-for="Input.Email" type="email" autocomplete="username" />
        </label>

        <label class="vf-field">
            <span>Password</span>
            <input asp-for="Input.Password" type="password" autocomplete="current-password" />
        </label>

        <button class="vf-primary-button" type="submit">Sign in</button>
    </form>
</section>
