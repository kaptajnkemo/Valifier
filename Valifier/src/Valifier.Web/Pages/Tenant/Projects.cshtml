@page "/tenant/projects"
@model Valifier.Web.Pages.Tenant.ProjectsModel
@{
    ViewData["Title"] = "Tenant projects";
}

<section class="vf-panel">
    <div class="vf-eyebrow">Tenant workspace</div>
    <h1>Projects</h1>

    <div class="vf-stat-card">
        <span>Total recruitment projects</span>
        <strong>@Model.Directory.TotalProjects</strong>
    </div>

    @if (Model.Directory.TotalProjects == 0)
    {
        <p>No recruitment projects found</p>
    }
    else
    {
        <ul class="vf-tenant-list">
            @foreach (var project in Model.Directory.Projects)
            {
                <li class="vf-tenant-row" data-testid="tenant-project-row">
                    <div>
                        <strong>@project.Title</strong>
                        <p>@project.Department</p>
                    </div>
                    <span>@project.Status</span>
                </li>
            }
        </ul>
    }
</section>
